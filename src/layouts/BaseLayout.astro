---
import { ViewTransitions } from 'astro:transitions';
import HeroCanvas from '../components/HeroCanvas.tsx';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Portfolio of Sai Kaushik Sudhakaran — PhD Researcher at IIT Delhi specialising in HPC, FHE, and Tsetlin Machines." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#050507" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <title>{title}</title>
    <!-- CLUE: The sequence is the name of the node. [NAME] -->
    <ViewTransitions />

    <!-- Lenis smooth scroll (lightweight, loaded inline) -->
    <script>
      // @ts-nocheck
      import Lenis from 'lenis';
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
      });
      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // --- CTF: Handshake Protocol [VOID] ---
      let keys = "";
      const sequence = "untitled";
      
      console.log("%c[SYSTEM] Unauthorized access detected. Use proper HANDSHAKE sequence to proceed.", "color: #00e5cc; font-family: monospace; font-weight: bold;");

      document.addEventListener('keydown', (e) => {
        keys += e.key.toLowerCase();
        keys = keys.slice(-sequence.length);
        
        if (keys === sequence) {
          // Visual feedback pulse
          document.body.style.transition = 'filter 0.3s ease';
          document.body.style.filter = 'invert(1) hue-rotate(180deg)';
          setTimeout(() => {
            document.body.style.filter = 'none';
            // Redirect using Astro View Transitions
            window.location.href = "/untitled";
          }, 350);
        }
      });
    </script>
  </head>
  <body>
    <!-- Global Persistent Background -->
    <div class="global-canvas" aria-hidden="true" transition:persist>
      <HeroCanvas client:idle />
    </div>

    <slot />
  </body>
</html>
