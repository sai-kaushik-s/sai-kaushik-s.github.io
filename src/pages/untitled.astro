---
import { ViewTransitions } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>∅ · untitled</title>
  <ViewTransitions />
  <style is:global>
    @font-face {
      font-family: 'Hermit';
      src: url('/fonts/Hermit-Regular.otf') format('opentype');
      font-weight: 400;
      font-style: normal;
    }
    @font-face {
      font-family: 'Hermit';
      src: url('/fonts/Hermit-Bold.otf') format('opentype');
      font-weight: 700;
      font-style: normal;
    }
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { height: 100%; overflow: hidden; background: #000; }
  </style>
</head>
<body>

<div class="void-shell" id="voidShell">
  <!-- Animated noise background -->
  <canvas class="noise-canvas" id="noiseCanvas" aria-hidden="true"></canvas>

  <!-- Glitch overlay lines -->
  <div class="glitch-lines" aria-hidden="true">
    <div class="gl gl1"></div>
    <div class="gl gl2"></div>
    <div class="gl gl3"></div>
  </div>

  <!-- Content -->
  <main class="void-content" aria-label="Untitled — hidden route">
    <div class="header-row">
      <span class="null-glyph" aria-hidden="true">∅</span>
      <span class="header-label">PROCESS_ID · NULL · ∞</span>
    </div>

    <h1 class="void-title" id="voidTitle">untitled</h1>

    <div class="log-console" role="log" aria-live="polite">
      <p class="log-line" data-delay="0">
        <span class="ts">00:00:00.000</span>
        <span class="msg">booting into undefined address space...</span>
      </p>
      <p class="log-line" data-delay="600">
        <span class="ts">00:00:00.012</span>
        <span class="msg warn">WARNING: observer collapsed the wavefunction</span>
      </p>
      <p class="log-line" data-delay="1200">
        <span class="ts">00:00:00.049</span>
        <span class="msg">initialising multiverse branch <span class="hl">ψ-7</span></span>
      </p>
      <p class="log-line" data-delay="1900">
        <span class="ts">00:00:00.301</span>
        <span class="msg">this path diverged from the main timeline.</span>
      </p>
      <p class="log-line" data-delay="2600">
        <span class="ts">00:00:00.512</span>
        <span class="msg">in another branch, the papers were already published.</span>
      </p>
      <p class="log-line" data-delay="3400">
        <span class="ts">00:00:01.001</span>
        <span class="msg warn">NOTICE: this page has no referrer. you found it yourself.</span>
      </p>
      <p class="log-line" data-delay="4200">
        <span class="ts">00:00:01.744</span>
        <span class="msg">good.</span>
      </p>
      <p class="log-line" id="cursorLine" data-delay="5000">
        <span class="ts">00:00:02.048</span>
        <span class="prompt">$</span>
        <span class="cursor-blink-void">█</span>
      </p>
    </div>

    <div class="bottom-row">
      <a href="/" class="return-link">← return()</a>
      <span class="branch-label">branch: ψ-7 · entropy: 1.0 · determinism: false</span>
    </div>
  </main>
</div>

<style>
  /* ── Shell ───────────────────────────────────────────── */
  .void-shell {
    position: relative;
    width: 100vw;
    height: 100vh;
    background: #000005;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    animation: glitch-entry 0.6s steps(3, end) forwards;
  }

  @keyframes glitch-entry {
    0%   { filter: hue-rotate(0deg)   brightness(3) blur(4px); clip-path: inset(0 0 0 0); }
    20%  { filter: hue-rotate(180deg) brightness(2) blur(2px); clip-path: inset(10% 0 60% 0); transform: translate(-4px, 2px); }
    40%  { filter: hue-rotate(90deg)  brightness(1.5); clip-path: inset(50% 0 10% 0); transform: translate(4px, -2px); }
    60%  { filter: hue-rotate(45deg)  brightness(1.2); clip-path: inset(0 0 0 0); transform: translate(-2px, 0); }
    80%  { filter: none; clip-path: inset(0 0 0 0); transform: translate(1px, 0); }
    100% { filter: none; clip-path: inset(0 0 0 0); transform: translate(0); }
  }

  /* ── Noise canvas ────────────────────────────────────── */
  .noise-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.04;
    pointer-events: none;
  }

  /* ── Glitch scan lines ───────────────────────────────── */
  .glitch-lines { position: absolute; inset: 0; pointer-events: none; }
  .gl {
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: rgba(123, 47, 255, 0.35);
    mix-blend-mode: screen;
  }
  .gl1 { animation: scan 8s  linear infinite; }
  .gl2 { animation: scan 13s linear infinite 3s; opacity: 0.5; }
  .gl3 { animation: scan 6s  linear infinite 1.5s; opacity: 0.25; }
  @keyframes scan {
    from { top: -2px; }
    to   { top: 100%; }
  }

  /* ── Content ─────────────────────────────────────────── */
  .void-content {
    position: relative;
    z-index: 1;
    max-width: min(640px, 90vw);
    width: 100%;
    padding: 0 0;
  }

  /* ── Header row ──────────────────────────────────────── */
  .header-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeup 0.4s ease 0.2s forwards;
  }
  .null-glyph {
    font-family: 'Hermit', monospace;
    font-size: 1.6rem;
    color: #7b2fff;
    text-shadow: 0 0 18px rgba(123,47,255,0.7);
  }
  .header-label {
    font-family: 'Hermit', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.22);
    text-transform: uppercase;
  }

  /* ── Title with chromatic aberration ─────────────────── */
  .void-title {
    font-family: 'Hermit', monospace;
    font-size: clamp(3rem, 10vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #e4e8f0;
    line-height: 1;
    margin-bottom: 2.5rem;
    position: relative;
    opacity: 0;
    animation: fadeup 0.5s ease 0.35s forwards;
  }
  .void-title::before {
    content: 'untitled';
    position: absolute;
    inset: 0;
    color: #00e5cc;
    clip-path: inset(0 0 60% 0);
    transform: translate(-3px, 1px);
    opacity: 0.7;
  }
  .void-title::after {
    content: 'untitled';
    position: absolute;
    inset: 0;
    color: #7b2fff;
    clip-path: inset(45% 0 0 0);
    transform: translate(3px, -1px);
    opacity: 0.7;
  }

  /* ── Console ─────────────────────────────────────────── */
  .log-console {
    display: flex;
    flex-direction: column;
    gap: 0.22rem;
    margin-bottom: 2.5rem;
    border-left: 1px solid rgba(123,47,255,0.25);
    padding-left: 1rem;
  }

  .log-line {
    font-family: 'Hermit', monospace;
    font-size: clamp(0.68rem, 1.3vw, 0.8rem);
    line-height: 1.7;
    display: flex;
    gap: 0.6em;
    opacity: 0;
    color: rgba(255,255,255,0.65);
  }
  .ts {
    color: rgba(123,47,255,0.55);
    flex-shrink: 0;
  }
  .msg { color: rgba(255,255,255,0.55); }
  .msg.warn { color: rgba(255,180,50,0.7); }
  .hl  { color: #00e5cc; }
  .prompt { color: #7b2fff; margin-right: 0.2em; }

  .cursor-blink-void {
    display: inline-block;
    color: #7b2fff;
    animation: cursor-blink-v 0.9s step-start infinite;
  }
  @keyframes cursor-blink-v { 0%,100%{opacity:1} 50%{opacity:0} }

  /* ── Bottom row ──────────────────────────────────────── */
  .bottom-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    opacity: 0;
    animation: fadeup 0.4s ease 5.5s forwards;
  }
  .return-link {
    font-family: 'Hermit', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: rgba(0,229,204,0.7);
    text-decoration: none;
    transition: color 0.2s, text-shadow 0.2s;
    display: inline-block;
  }
  .return-link:hover {
    color: #00e5cc;
    text-shadow: 0 0 12px rgba(0,229,204,0.5);
  }
  .branch-label {
    font-family: 'Hermit', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.2);
  }

  @keyframes fadeup {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: none; }
  }
</style>

<script>
  // @ts-nocheck
  // Animated log lines
  const logLines = document.querySelectorAll('.log-line');
  logLines.forEach(line => {
    const delay = parseInt(line.dataset.delay || '0', 10);
    line.style.animationDelay = `${delay}ms`;
    line.style.animation = `fadeup 0.4s ease ${delay}ms forwards`;
  });

  // Noise canvas
  const canvas = document.getElementById('noiseCanvas');
  if (canvas) {
    const ctx = canvas.getContext('2d');
    function resize() {
      if (canvas) {
        canvas.width  = window.innerWidth;
        canvas.height = window.innerHeight;
      }
    }
    resize();
    window.addEventListener('resize', resize);
    function drawNoise() {
      if (ctx && canvas) {
        const id = ctx.createImageData(canvas.width, canvas.height);
        const d  = id.data;
        for (let i = 0; i < d.length; i += 4) {
          const v = Math.random() * 255 | 0;
          d[i] = d[i+1] = d[i+2] = v;
          d[i+3] = 18;
        }
        ctx.putImageData(id, 0, 0);
      }
      requestAnimationFrame(drawNoise);
    }
    drawNoise();
  }
</script>

</body>
</html>
